// Neutron Space — Main UI
// Pure declarative UI in Slint (no Java/Kotlin)

import { Button, ListView, VerticalBox, HorizontalBox, LineEdit, ScrollView } from "std-widgets.slint";

export struct AppEntry {
    id: int,
    name: string,
    package-name: string,
    version: string,
    size-mb: string,
    is-running: bool,
    gg-compat: bool,
}

export struct FileEntry {
    name: string,
    path: string,
    size-mb: string,
    is-dir: bool,
}

export component NeutronApp inherits Window {
    title: "Neutron Space";
    preferred-width: 400px;
    preferred-height: 720px;
    background: #1a1a2e;

    in-out property <[AppEntry]> installed-apps: [];
    in-out property <[FileEntry]> file-list: [];
    in-out property <string> status-text: "Ready";
    in-out property <string> current-path: "/storage/emulated/0";
    in-out property <bool> importing: false;
    in-out property <bool> show-file-browser: false;

    callback import-apk();
    callback launch-app(int);
    callback stop-app(int);
    callback uninstall-app(int);
    callback toggle-gg(int);
    callback select-file(string);
    callback navigate-dir(string);
    callback close-browser();

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        // Header
        HorizontalBox {
            spacing: 8px;
            Text {
                text: "Neutron Space";
                font-size: 24px;
                font-weight: 700;
                color: #e94560;
                vertical-alignment: center;
            }
            Rectangle { }
            Text {
                text: "v1.0";
                font-size: 12px;
                color: #666;
                vertical-alignment: center;
            }
        }

        // Status bar
        Rectangle {
            height: 32px;
            border-radius: 6px;
            background: #16213e;
            HorizontalBox {
                padding-left: 12px;
                padding-right: 12px;
                Text {
                    text: root.status-text;
                    font-size: 12px;
                    color: #aaa;
                    vertical-alignment: center;
                }
            }
        }

        if !root.show-file-browser: VerticalBox {
            spacing: 12px;

            // Action buttons
            HorizontalBox {
                spacing: 8px;
                Button {
                    text: importing ? "Importing..." : "Import APK/XAPK";
                    enabled: !importing;
                    clicked => { root.import-apk(); }
                }
            }

            // App list
            Text {
                text: "Installed Apps (" + installed-apps.length + ")";
                font-size: 14px;
                font-weight: 600;
                color: #ccc;
            }

            ListView {
                for app in root.installed-apps: Rectangle {
                    height: 80px;
                    border-radius: 8px;
                    background: #16213e;

                    HorizontalBox {
                        padding: 12px;
                        spacing: 12px;

                        // App icon placeholder
                        Rectangle {
                            width: 48px;
                            height: 48px;
                            border-radius: 8px;
                            background: #e94560;
                            Text {
                                text: app.name;
                                font-size: 16px;
                                color: white;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                overflow: clip;
                            }
                        }

                        // App info
                        VerticalBox {
                            spacing: 4px;
                            Text {
                                text: app.name;
                                font-size: 14px;
                                font-weight: 600;
                                color: white;
                            }
                            Text {
                                text: app.package-name;
                                font-size: 11px;
                                color: #888;
                            }
                            HorizontalBox {
                                spacing: 8px;
                                Text {
                                    text: "v" + app.version;
                                    font-size: 10px;
                                    color: #666;
                                }
                                Text {
                                    text: app.size-mb + " MB";
                                    font-size: 10px;
                                    color: #666;
                                }
                                Text {
                                    text: app.is-running ? "Running" : "Stopped";
                                    font-size: 10px;
                                    color: app.is-running ? #4caf50 : #666;
                                }
                                Text {
                                    text: app.gg-compat ? "GG" : "";
                                    font-size: 10px;
                                    color: #ff9800;
                                }
                            }
                        }

                        Rectangle { }

                        // Action buttons
                        VerticalBox {
                            spacing: 4px;
                            Button {
                                text: app.is-running ? "Stop" : "Launch";
                                clicked => {
                                    if app.is-running {
                                        root.stop-app(app.id);
                                    } else {
                                        root.launch-app(app.id);
                                    }
                                }
                            }
                            Button {
                                text: app.gg-compat ? "GG: ON" : "GG: OFF";
                                clicked => { root.toggle-gg(app.id); }
                            }
                        }
                    }
                }
            }
        }

        // File browser view
        if root.show-file-browser: VerticalBox {
            spacing: 8px;

            // Browser header
            HorizontalBox {
                spacing: 8px;
                Text {
                    text: "Select APK/XAPK";
                    font-size: 16px;
                    font-weight: 600;
                    color: white;
                    vertical-alignment: center;
                }
                Rectangle { }
                Button {
                    text: "Cancel";
                    clicked => { root.close-browser(); }
                }
            }

            // Current path
            Rectangle {
                height: 28px;
                border-radius: 4px;
                background: #0f3460;
                HorizontalBox {
                    padding-left: 8px;
                    padding-right: 8px;
                    Text {
                        text: root.current-path;
                        font-size: 11px;
                        color: #8ec5fc;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // Navigate up button
            Rectangle {
                height: 44px;
                border-radius: 6px;
                background: #1f2937;
                TouchArea {
                    clicked => { root.navigate-dir(".."); }
                }
                HorizontalBox {
                    padding-left: 12px;
                    spacing: 8px;
                    Text {
                        text: "..";
                        font-size: 18px;
                        font-weight: 700;
                        color: #60a5fa;
                        vertical-alignment: center;
                    }
                    Text {
                        text: "Go up";
                        font-size: 13px;
                        color: #9ca3af;
                        vertical-alignment: center;
                    }
                }
            }

            // File list
            ListView {
                for file in root.file-list: Rectangle {
                    height: 52px;
                    border-radius: 6px;
                    background: file.is-dir ? #1f2937 : #16213e;
                    
                    TouchArea {
                        clicked => {
                            if file.is-dir {
                                root.navigate-dir(file.path);
                            } else {
                                root.select-file(file.path);
                            }
                        }
                    }

                    HorizontalBox {
                        padding: 12px;
                        spacing: 10px;

                        // Icon
                        Rectangle {
                            width: 32px;
                            height: 32px;
                            border-radius: 6px;
                            background: file.is-dir ? #3b82f6 : #10b981;
                            Text {
                                text: file.is-dir ? "D" : "A";
                                font-size: 14px;
                                font-weight: 700;
                                color: white;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // File info
                        VerticalBox {
                            spacing: 2px;
                            Text {
                                text: file.name;
                                font-size: 13px;
                                color: white;
                                overflow: elide;
                            }
                            Text {
                                text: file.is-dir ? "Folder" : file.size-mb + " MB";
                                font-size: 11px;
                                color: #666;
                            }
                        }
                    }
                }
            }
        }

        // Footer
        Text {
            text: "Neutron Virtual Space — No Root Required";
            font-size: 10px;
            color: #444;
            horizontal-alignment: center;
        }
    }
}
